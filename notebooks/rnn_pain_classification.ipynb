      }
    },
    {
      "cell_type": "code",
      "source": [
        "best_dropout_rate = best_config[\"dropout_rate\"]\n",
        "best_hidden_size = best_config[\"hidden_size\"]\n",
        "best_bidirectional = best_config[\"bidirectional\"]\n",
        "best_window_size = best_config[\"window_size\"]\n",
        "best_stride = best_config[\"stride\"]"
      ],
      "metadata": {
        "id": "Ap11nJLrj8fu"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Full Training Data Preparation"
      ],
      "metadata": {
        "id": "2WkYtliWkAKZ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "X_train_final = X_train_base.copy()\n",
        "X_test_final = X_test_base.copy()\n",
        "y_train_final = y_train.copy()\n",
        "\n",
        "X_train_final = apply_feature_engineering(X_train_final)\n",
        "X_test_final = apply_feature_engineering(X_test_final)\n",
        "\n",
        "X_train_processed, X_test_processed, preprocessing_pipeline = preprocess_full_train_and_test(\n",
        "    X_train_final,\n",
        "    X_test_final,\n",
        ")\n",
        "\n",
        "label_encoder = LabelEncoder()\n",
        "label_encoder.fit(y_train_final[\"label\"])\n",
        "\n",
        "train_sample_indices = X_train_processed[\"sample_index\"].unique()\n",
        "train_sequences, train_labels, _ = create_sequences(\n",
        "    X_train_processed,\n",
        "    y_train_final,\n",
        "    train_sample_indices,\n",
        "    best_window_size,\n",
        "    best_stride,\n",
        "    label_encoder,\n",
        ")\n",
        "\n",
        "test_sample_indices = X_test_processed[\"sample_index\"].unique()\n",
        "test_sequences, test_labels, test_sample_indices_for_sequences = create_sequences(\n",
        "    X_test_processed,\n",
        "    pd.DataFrame(),\n",
        "    test_sample_indices,\n",
        "    best_window_size,\n",
        "    best_stride,\n",
        "    None,\n",
        ")\n",
        "\n",
        "input_shape = train_sequences.shape[1:]\n",
        "num_classes = len(np.unique(train_labels))"
      ],
      "metadata": {
        "id": "THGllxZjkBD6"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Final DataLoaders"
      ],
      "metadata": {
        "id": "VrGO-MDHkHvX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "train_ds = TensorDataset(\n",
        "    torch.from_numpy(train_sequences).float(),\n",
        "    torch.from_numpy(train_labels).long(),\n",
        ")\n",
        "\n",
        "test_sequences_tensor = torch.from_numpy(test_sequences).float()\n",
        "\n",
        "train_loader = DataLoader(\n",
        "    train_ds,\n",
        "    batch_size=BATCH_SIZE,\n",
        "    shuffle=True,\n",
        "    num_workers=NUM_WORKERS,\n",
        "    pin_memory=torch.cuda.is_available(),\n",
        ")\n",
        "\n",
        "test_ds = TensorDataset(test_sequences_tensor)\n",
        "test_loader = DataLoader(\n",
        "    test_ds,\n",
        "    batch_size=BATCH_SIZE,\n",
        "    shuffle=False,\n",
        ")"
      ],
      "metadata": {
        "id": "-QazN1bRkJyc"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Final Model Training"
      ],
      "metadata": {
        "id": "OIQipZ2bkMWy"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "final_model = RecurrentClassifier(\n",
        "    input_size=input_shape[-1],\n",
        "    hidden_size=best_hidden_size,\n",
        "    num_layers=HIDDEN_LAYERS,\n",
        "    num_classes=num_classes,\n",
        "    dropout_rate=best_dropout_rate,\n",
        "    rnn_type=RNN_TYPE,\n",
        "    bidirectional=best_bidirectional,\n",
        ").to(device)\n",
        "\n",
        "optimizer = torch.optim.AdamW(\n",
        "    final_model.parameters(),\n",
        "    lr=LEARNING_RATE,\n",
        "    weight_decay=WEIGHT_DECAY,\n",
        ")\n",
        "\n",
        "criterion = FocalLossWithSmoothing(alpha=alpha_tensor, gamma=1.0, smoothing=0.1)\n",
        "scaler = torch.amp.GradScaler(enabled=(device.type == \"cuda\"))\n",
        "\n",
        "scheduler = torch.optim.lr_scheduler.OneCycleLR(\n",
        "    optimizer,\n",
        "    max_lr=MAX_LR,\n",
        "    steps_per_epoch=len(train_loader),\n",
        "    epochs=EPOCHS,\n",
        "    pct_start=0.3,\n",
        "    anneal_strategy=\"cos\",\n",
        "    div_factor=10,\n",
        "    final_div_factor=100,\n",
        ")\n",
        "\n",
        "final_model, final_training_history = fit(\n",
        "    model=final_model,\n",
        "    train_loader=train_loader,\n",
        "    val_loader=None,\n",
        "    epochs=EPOCHS,\n",
        "    criterion=criterion,\n",
        "    optimizer=optimizer,\n",
        "    scaler=scaler,\n",
        "    device=device,\n",
        "    verbose=VERBOSE,\n",
        "    l1_lambda=L1_LAMBDA,\n",
        "    restore_best_weights=False,\n",
        "    scheduler=scheduler,\n",
        "    experiment_name=\"final_model\",\n",
        ")"
      ],
      "metadata": {
        "id": "vEgMfPg3kOZO"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Test Inference and Submission"
      ],
      "metadata": {
        "id": "7TiZQqoOkRap"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "final_model.eval()\n",
        "all_preds = []\n",
        "\n",
        "with torch.no_grad():\n",
        "    for xb in test_loader:\n",
        "        xb = xb[0].to(device)\n",
        "        logits = final_model(xb)\n",
        "        preds = torch.argmax(logits, dim=1)\n",
        "        all_preds.extend(preds.cpu().numpy())\n",
        "\n",
        "final_submission = build_submission_from_sequence_predictions(\n",
        "    test_sample_indices_for_sequences,\n",
        "    all_preds,\n",
        "    label_encoder,\n",
        ")\n",
        "\n",
        "final_submission.to_csv(\"FINAL_SUBMISSION_5.csv\", index=False)\n",
        "print(\"Saved FINAL_SUBMISSION_5.csv\")"
      ],
      "metadata": {
        "id": "GZkR89F_kTYw"
      },
      "execution_count": null,
      "outputs": []
    },
