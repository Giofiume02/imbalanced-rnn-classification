        "X_train, X_test, zero_var_cols = remove_zero_variance_columns(X_train, X_test)\n",
        "print(\"Zero-variance columns:\", zero_var_cols)\n",
        "\n",
        "X_train, X_test, high_corr_cols = remove_high_correlation_features(X_train, X_test, threshold=0.90)\n",
        "print(\"Highly correlated columns:\", high_corr_cols)"
