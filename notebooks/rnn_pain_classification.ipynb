        "else:\n",
        "    print(\"No validation labels were generated.\")\n",
        "\n",
        "test_sample_indices = X_test_processed['sample_index'].unique()\n",
        "\n",
        "test_sequences, test_labels, test_sample_indices_for_sequences = create_sequences(\n",
        "    X_test_processed,\n",
        "    pd.DataFrame(),\n",
        "    test_sample_indices,\n",
        "    WINDOW_SIZE,\n",
        "    STRIDE,\n",
        "    None\n",
        ")\n",
        "\n",
        "print(f\"\\nTest sequences shape: {test_sequences.shape}\")\n",
        "if test_labels is not None:\n",
        "    print(f\"Test labels shape: {test_labels.shape}\")\n",
        "else:\n",
        "    print(\"No test labels were generated (expected for test set).\")\n",
        "\n",
        "print(f\"Number of test sample indices for sequences: {len(test_sample_indices_for_sequences)}\")\n",
        "\n"
      ],
      "metadata": {
        "id": "y4DRdByOLDOg"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Input Shape and Number of Classes"
      ],
      "metadata": {
        "id": "iMrHNktsLXf-"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "input_shape = train_sequences.shape[1:]\n",
        "print(f\"Input shape for the model: {input_shape}\")\n",
        "\n",
        "\n",
        "\n",
        "if train_labels is not None:\n",
        "    num_classes = len(np.unique(train_labels))\n",
        "    print(f\"Number of classes: {num_classes}\")\n",
        "else:\n",
        "    print(\"Cannot determine number of classes as training labels were not generated.\")\n",
        "    num_classes = None\n"
      ],
      "metadata": {
        "id": "FCyr8lCqLaeA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## DataLoaders"
      ],
      "metadata": {
        "id": "52Ret7j6Lq9N"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "BATCH_SIZE = 64\n",
        "NUM_WORKERS = 2\n",
        "\n",
        "train_ds, val_ds, train_loader, val_loader = build_dataloaders(\n",
        "    train_sequences,\n",
        "    train_labels,\n",
        "    val_sequences,\n",
        "    val_labels,\n",
        "    batch_size=BATCH_SIZE,\n",
        "    num_workers=NUM_WORKERS,\n",
        ")\n",
        "\n",
        "test_sequences_tensor = torch.from_numpy(test_sequences).float()\n",
        "\n",
        "print(f\"Training dataset size: {len(train_ds)}\")\n",
        "print(f\"Validation dataset size: {len(val_ds)}\")\n",
        "print(f\"Test sequences tensor shape: {test_sequences_tensor.shape}\")\n",
        "\n",
        "print(f\"Number of batches in training loader: {len(train_loader)}\")\n",
        "print(f\"Number of batches in validation loader: {len(val_loader)}\")\n",
        "\n",
        "for xb, yb in train_loader:\n",
        "    print(\"Features batch shape:\", xb.shape)\n",
        "    print(\"Labels batch shape:\", yb.shape)\n",
        "    break"
      ],
      "metadata": {
        "id": "X6IkXqsALqPs"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Model Training\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n"
      ],
      "metadata": {
        "id": "gZ2Fh_AONTLX"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Training Configuration\n",
        "\n",
        "The following section defines the training hyperparameters, initializes the recurrent model, configures TensorBoard logging, and launches the training procedure."
      ],
      "metadata": {
        "id": "RHx0Rv_V9vzd"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "LEARNING_RATE = 1e-4\n",
        "MAX_LR = 1e-4\n",
        "EPOCHS = 10\n",
        "PATIENCE = 2\n",
        "\n",
        "HIDDEN_LAYERS = 2\n",
        "HIDDEN_SIZE = 128\n",
        "\n",
        "DROPOUT_RATE = 0.1\n",
        "L1_LAMBDA = 0.0\n",
        "WEIGHT_DECAY = 1e-4"
      ],
      "metadata": {
        "id": "7CaUxUtb9yhK"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Model Initialization"
      ],
      "metadata": {
        "id": "12me9_RXcuRR"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "rnn_model = RecurrentClassifier(\n",
        "    input_size=input_shape[-1],\n",
        "    hidden_size=HIDDEN_SIZE,\n",
        "    num_layers=HIDDEN_LAYERS,\n",
        "    num_classes=num_classes,\n",
        "    dropout_rate=DROPOUT_RATE,\n",
        "    bidirectional=False,\n",
        "    rnn_type=\"LSTM\",\n",
        ").to(device)\n",
        "\n",
        "recurrent_summary(rnn_model, input_size=input_shape)"
      ],
      "metadata": {
        "id": "QwnCHiByb8vT"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Experiment Setup\n",
        "\n",
        "This step defines the loss function, optimizer, learning-rate schedule, mixed-precision scaler, and TensorBoard logging configuration."
      ],
      "metadata": {
        "id": "HfYjU6Wjb_Dw"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "experiment_name = \"cnn_lstm_attention\"\n",
        "\n",
        "writer = SummaryWriter(f\"./{logs_dir}/{experiment_name}\")\n",
        "x = torch.randn(1, input_shape[0], input_shape[1]).to(device)\n",
        "writer.add_graph(rnn_model, x)\n",
        "\n",
        "criterion = FocalLossWithSmoothing(alpha=alpha_tensor, gamma=2.0, smoothing=0.1)\n",
        "\n",
        "optimizer = torch.optim.AdamW(\n",
        "    rnn_model.parameters(),\n",
        "    lr=LEARNING_RATE,\n",
        "    weight_decay=WEIGHT_DECAY,\n",
        ")\n",
        "\n",
        "scheduler = torch.optim.lr_scheduler.OneCycleLR(\n",
        "    optimizer,\n",
        "    max_lr=MAX_LR,\n",
        "    steps_per_epoch=len(train_loader),\n",
        "    epochs=EPOCHS,\n",
        "    pct_start=0.3,\n",
        "    anneal_strategy=\"cos\",\n",
        "    div_factor=10,\n",
        "    final_div_factor=100,\n",
        ")\n",
        "\n",
        "scaler = torch.amp.GradScaler(enabled=(device.type == \"cuda\"))"
      ],
      "metadata": {
        "id": "FHE--JYVcAGy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Training Execution\n",
        "\n",
        "The model is trained using the custom training loop defined in `src/train.py`, with validation monitoring and early stopping."
      ],
      "metadata": {
        "id": "BfpWoEpNcEaM"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "rnn_model, training_history = fit(\n",
        "    model=rnn_model,\n",
        "    train_loader=train_loader,\n",
        "    val_loader=val_loader,\n",
        "    epochs=EPOCHS,\n",
        "    criterion=criterion,\n",
        "    optimizer=optimizer,\n",
        "    scaler=scaler,\n",
        "    device=device,\n",
        "    l1_lambda=L1_LAMBDA,\n",
        "    writer=writer,\n",
        "    verbose=1,\n",
        "    experiment_name=experiment_name,\n",
        "    patience=PATIENCE,\n",
        "    scheduler=scheduler,\n",
        ")"
      ],
      "metadata": {
        "id": "RpDZI6xqcFcF"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Cross-Validation"
      ],
      "metadata": {
        "id": "jlK2FoB4trD7"
