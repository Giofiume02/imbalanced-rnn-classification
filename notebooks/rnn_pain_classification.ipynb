      "cell_type": "markdown",
      "source": [
        "# Pain Level Classification from Time-Series Data with Recurrent Neural Networks\n",
        "This notebook documents the end-to-end workflow for multiclass pain-level classification from multivariate time-series data.  \n",
        "It covers data preprocessing, feature engineering, window-size analysis, recurrent model training, and final evaluation."
      ],
      "metadata": {
        "id": "GfHo4SEeSluZ"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## Setup and Imports\n",
        "\n",
        "This section initializes the environment, imports the required libraries and project modules, sets the random seed for reproducibility, and configures the computation device and plotting style."
      ],
      "metadata": {
        "id": "tgCXdob3SMtK"
      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "jdiB29durc6m"
      },
      "outputs": [],
      "source": [
        "SEED = 42\n",
        "\n",
        "import os\n",
        "import warnings\n",
        "import random\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import torch\n",
        "\n",
        "from torch.utils.data import TensorDataset, DataLoader\n",
        "from torch.utils.tensorboard import SummaryWriter\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "from src.preprocessing import (\n",
        "    create_sequences,\n",
        "    convert_joint_columns_to_float32,\n",
        "    remove_zero_variance_columns,\n",
        "    remove_high_correlation_features,\n",
        "    fit_label_encoder_and_compute_alpha,\n",
        "    split_train_validation_by_sample,\n",
        "    preprocess_and_transform_datasets,\n",
        "    build_dataloaders,\n",
        "    preprocess_full_train_and_test,\n",
        ")\n",
        "\n",
        "from src.feature_engineering import (\n",
        "    analyze_autocorrelation,\n",
        "    apply_feature_engineering,\n",
        ")\n",
        "\n",
        "from src.models import (\n",
        "    RecurrentClassifier,\n",
        "    FocalLossWithSmoothing,\n",
        "    recurrent_summary,\n",
        ")\n",
        "\n",
        "from src.train import fit\n",
        "\n",
        "from src.evaluate import (\n",
        "    plot_confusion_for_fold,\n",
        "    plot_aggregated_confusion_matrix_cv,\n",
        "    plot_aggregated_roc_auc_cv,\n",
        ")\n",
        "\n",
        "from src.cross_validation import run_stratified_kfold_cv\n",
        "from src.hyperparameter_tuning import grid_search_cv_rnn\n",
        "from src.ensemble import build_weighted_ensemble_submission\n",
        "\n",
        "os.environ[\"PYTHONHASHSEED\"] = str(SEED)\n",
        "\n",
        "warnings.simplefilter(action=\"ignore\", category=FutureWarning)\n",
        "warnings.simplefilter(action=\"ignore\", category=Warning)\n",
        "\n",
        "np.random.seed(SEED)\n",
        "random.seed(SEED)\n",
        "torch.manual_seed(SEED)\n",
        "\n",
        "if torch.cuda.is_available():\n",
        "    device = torch.device(\"cuda\")\n",
        "    torch.cuda.manual_seed_all(SEED)\n",
        "    torch.backends.cudnn.benchmark = True\n",
        "else:\n",
        "    device = torch.device(\"cpu\")\n",
        "\n",
        "sns.set(font_scale=1.2)\n",
        "sns.set_style(\"white\")\n",
        "plt.rc(\"font\", size=12)\n",
        "\n",
        "print(f\"PyTorch version: {torch.__version__}\")\n",
        "print(f\"Device: {device}\")"
      ]
    },
